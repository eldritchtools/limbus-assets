        {
          "desc": "Takes -30% damage from [Combustion], [Laceration], [Vibration], and [Burst] (rounded down)\n-50% to the amount of Stagger Threshold raised (rounded down)",
          "name": "Vengeance Tattoos [<s>Great Brother</s>]"
        },
        {
          "desc": "Encounter Start: Inflict [VengeanceBookSpider] on all Sinners\n\nIf this unit hit with more than 3 Skills this turn, gain 1 [ReinforcedTattooSpider] next turn for every excess Skill that hit",
          "name": "The Book of Vengeance"
        },
        {
          "desc": "On Clash Win, gain 1 [DaughterEducationSpider]\n\nOn Hit with a Skill, gain 1 [DaughterEducationSpider] (once per Skill; this effect does not activate for Cracked Coins)\n\nOn Clash Win with the first-used Skill in a turn, gain 1 more [DaughterEducationSpider] and the Skill gains Coin Power +1",
          "name": "My Daughter's Education"
        },
        {
          "desc": "When hit by 2 Skills, gain 1 [ResentmentSpider] and lose 1 [DaughterEducationSpider] (number of hits taken is always tracked)\n\nAt max [ResentmentSpider] Stack, use a powerful attack\n\nTurn End: At less than 90% / 60% / 40% HP, max out this unit's [ResentmentSpider] Stack",
          "name": "Resentment"
        },
        {
          "desc": "When [MiddleFatherSwordFour] is unsealed, this unit gains [MiddleFatherGutsMirror]",
          "name": "Vengeance Tattoos Max Output... Unseal Lævateinn!"
        },
        {
          "desc": "Turn End: if in Panic, reset SP to 0.",
          "name": "Panic Recovery"
        },
        {
          "desc": "This unit's Panic Type does not change when inflicted with an effect that changes Panic Types. Instead, this unit is inflicted with an effect that is inflicted against targets without SP.",
          "name": "Fixed Panic"
        }
